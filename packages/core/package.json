{
	"name": "@telia-oss/xjog",
	"version": "0.2.0",
	"description": "XState chart runner for long-running charts",
	"engines": {
		"npm": ">=8.19.4",
		"node": ">=24.x",
		"pnpm": ">=10.34.1"
	},
	"keywords": [
		"statechart",
		"harel",
		"xstate"
	],
	"repository": "https://github.com/telia-oss/xjog",
	"homepage": "https://github.com/telia-oss/xjog",
	"author": "Sami Hult <sami.hult@gmail.com>",
	"license": "MIT",
	"private": false,
	"main": "lib",
	"files": [
		"lib/**/*"
	],
	"scripts": {
		"build": "pnpm exec tsc",
		"test": "NODE_OPTIONS='--experimental-vm-modules --disable-warning=ExperimentalWarning' pnpm exec jest --config jestconfig.js --passWithNoTests",
		"lint": "pnpm exec biome ci .",
		"lint:fix": "pnpm exec biome check --write .",
		"format": "pnpm exec biome format --write .",
		"prepublishOnly": "pnpm run lint && pnpm run build && echo 'should also run: pnpm run test + pnpm run check'",
		"clean": "rm -rf node_modules lib"
	},
	"dependencies": {
		"@telia-oss/xjog-core-persistence": "workspace:^",
		"@telia-oss/xjog-util": "workspace:^",
		"async-mutex": "^0.3.2",
		"xstate": "4.38.3"
	},
	"devDependencies": {
		"@telia-oss/xjog-core-pglite": "workspace:^",
		"@types/express": "^4.17.13",
		"@types/pg": "8.20.0",
		"glob": "^8.0.3"
	},
	"gitHead": "296d7424a400009e863c25c455dd4b5d26139dcb",
	"peerDependencies": {
		"rxjs": "^7.8.2"
	},
	"publishConfig": {
		"registry": "https://jfrog.teliacompany.io/artifactory/api/npm/ecom-npm-local/",
		"access": "restricted"
	}
}
