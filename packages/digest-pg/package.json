{
	"name": "@telia-oss/xjog-digest-pg",
	"version": "0.2.0",
	"description": "XJog Postgres digest persistence",
	"engines": {
		"npm": ">=8.19.4",
		"node": ">=24.x",
		"pnpm": ">=10.34.1"
	},
	"keywords": [
		"statechart",
		"harel",
		"xjog"
	],
	"repository": "https://github.com/telia-oss/xjog",
	"homepage": "https://github.com/telia-oss/xjog",
	"author": "Sami Hult <sami.hult@gmail.com>",
	"license": "MIT",
	"private": false,
	"main": "lib",
	"files": [
		"lib/**/*"
	],
	"scripts": {
		"build": "pnpm run build:bin && pnpm run build:files",
		"build:bin": "pnpm exec tsc",
		"build:files": "pnpm exec cpx-fixed 'src/**/*.sql' lib",
		"prePublishOnly": "pnpm run build",
		"clean": "rm -rf node_modules lib",
		"lint": "pnpm exec biome ci .",
		"lint:fix": "pnpm exec biome check --write .",
		"format": "pnpm exec biome format --write ."
	},
	"dependencies": {
		"@telia-oss/xjog-digest-persistence": "workspace:^",
		"@telia-oss/xjog-util": "workspace:^",
		"node-pg-migrate": "^6.2.1",
		"pg": "^8.21.0",
		"pg-bind": "^1.0.1",
		"pg-listen": "^1.7.0",
		"rfc6902": "^5.0.1"
	},
	"devDependencies": {
		"@types/pg": "8.20.0"
	},
	"gitHead": "296d7424a400009e863c25c455dd4b5d26139dcb",
	"publishConfig": {
		"registry": "https://jfrog.teliacompany.io/artifactory/api/npm/ecom-npm-local/",
		"access": "restricted"
	}
}
