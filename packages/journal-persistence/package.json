{
  "name": "@samihult/xjog-journal-persistence",
  "version": "0.0.59",
  "description": "XJog chart abstract journal persistence adapter",
  "engines": {
    "npm": ">=8.19.4",
    "node": ">=24.x",
    "pnpm": ">=10.33.0"
  },
  "keywords": [
    "statechart",
    "harel",
    "xjog"
  ],
  "repository": "https://github.com/samihult/xjog",
  "homepage": "https://www.xjog.io/",
  "author": "Sami Hult <sami.hult@gmail.com>",
  "license": "MIT",
  "private": false,
  "main": "lib",
  "files": [
    "lib/**/*"
  ],
  "scripts": {
    "build": "pnpm run build:bin && pnpm run build:files",
    "build:bin": "tsc",
    "build:files": "cpx-fixed 'src/**/*.sql' lib",
    "prePublishOnly": "pnpm run build",
    "clean": "rm -rf node_modules lib"
  },
  "dependencies": {
    "@samihult/xjog-util": "workspace:^",
    "rfc6902": "^5.0.1",
    "uuid": "^8.3.2",
    "xstate": "4.26.1"
  },
  "devDependencies": {
    "@types/jest": "^27.0.1",
    "@types/node": "^16.7.10",
    "@typescript-eslint/eslint-plugin": "^5.40.0",
    "@typescript-eslint/parser": "^5.40.0",
    "cpx-fixed": "^1.6.0",
    "jest": "^28.1.2",
    "prettier": "^2.3.2",
    "typescript": "^4.7.4"
  },
  "gitHead": "296d7424a400009e863c25c455dd4b5d26139dcb",
  "peerDependencies": {
    "rxjs": "^7.8.2"
  }
}
